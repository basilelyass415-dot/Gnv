def winner():
  #حالات الفوز الافقيه
  for row in range(4):
    if game_btuns[row][0]["text"]==game_btuns[row][1]["text"]==game_btuns[row][2]["text"] !="":
      game_btuns[row][0].config(bg="black")
      game_btuns[row][1].config(bg="black")
      game_btuns[row][2].config(bg="black")
      return True
      
      
      #حالات الفوز العموديه
      
      
  for col in range(3):
    if game_btuns[0][col]["text"]==game_btuns[1][col]["text"]==game_btuns[2][col]["text"] !="":
      game_btuns[0][col].config(bg="black")
      game_btuns[1][col].config(bg="black")
      game_btuns[2][col].config(bg="black")
      return True
      
      #حالات الفوز التي بالزوايا
  
  
  for col in range(3):
    if game_btuns[1][col]["text"]==game_btuns[2][col]["text"]==game_btuns[3][col]["text"] !="":
      game_btuns[1][col].config(bg="black")
      game_btuns[2][col].config(bg="black")
      game_btuns[3][col].config(bg="black")
      return True
      
      #حالات الفوز التي بالزوايا
      
      
  if game_btuns[1][2]["text"]==game_btuns[2][1]["text"]==game_btuns[3][0]["text"] !="":
    game_btuns[1][2].config(bg="black")
    game_btuns[2][1].config(bg="black")
    game_btuns[3][0].config(bg="black")
    return True
    
    
      
      
      #حالات الفوز التي بالزوايا
      
      
  if game_btuns[1][0]["text"]==game_btuns[2][1]["text"]==game_btuns[3][2]["text"] !="":
    game_btuns[1][0].config(bg="black")
    game_btuns[2][1].config(bg="black")
    game_btuns[3][2].config(bg="black")
    return True
    
    
      
      
      #حالات الفوز التي بالزوايا
      
      
  if game_btuns[0][0]["text"]==game_btuns[1][1]["text"]==game_btuns[2][2]["text"] !="":
    game_btuns[0][0].config(bg="black")
    game_btuns[1][1].config(bg="black")
    game_btuns[2][2].config(bg="black")
    return True
    
    
      
      
      #حالات الفوز التي بالزوايا


  elif game_btuns[0][2]["text"]==game_btuns[1][1]["text"]==game_btuns[2][0]["text"] !="":
    game_btuns[0][2].config(bg="black")
    game_btuns[1][1].config(bg="black")
    game_btuns[2][0].config(bg="black")
    return True
      
      
  elif check_empty_spaces()==False:
    for row in range(4):
      for col in range(3):
        game_btuns[row][col].config(bg="red")
    return "tie"
  else:
    return False
    
    
def check_empty_spaces():
  spaces=12
  for row in range(4):
    for col in range(3):
      if game_btuns[row][col]["text"] !="":
        spaces -=1
  if spaces==0:
    return False
  else:
    return True
    
    
